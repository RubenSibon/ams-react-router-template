{
    "name": "ams-react-router-template",
    "private": true,
    "type": "module",
    "engines": {
        "node": "24",
        "pnpm": "11"
    },
    "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
    "scripts": {
        "dev": "react-router dev",
        "build": "react-router build",
        "start": "react-router-serve ./build/server/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "run-s --continue-on-error lint:**",
        "lint:js": "eslint .",
        "lint:css": "stylelint ./**/*.css",
        "lint-fix": "run-s --continue-on-error lint-fix:**",
        "lint-fix:js": "eslint . --fix",
        "lint-fix:css": "stylelint ./**/*.css --fix",
        "typegen": "react-router typegen",
        "prepare": "husky",
        "clean": "rimraf .react-router && rimraf build && rimraf package-lock.json && rimraf yarn.lock && rimraf node_modules"
    },
    "lint-staged": {
        "config": "ts-node lint-staged.config.ts"
    },
    "dependencies": {
        "@amsterdam/design-system-assets": "^2.3.0",
        "@amsterdam/design-system-css": "^3.3.0",
        "@amsterdam/design-system-react": "^3.3.0",
        "@amsterdam/design-system-react-icons": "^2.0.0",
        "@amsterdam/design-system-tokens": "^3.4.0",
        "@react-router/node": "^7.17.0",
        "@react-router/serve": "^7.17.0",
        "isbot": "^5.1.43",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router": "^7.17.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^0.14.0",
        "@eslint/markdown": "^7.5.1",
        "@react-router/dev": "^7.17.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^3.2.6",
        "eslint": "^9.39.4",
        "eslint-plugin-jest-dom": "^5.5.0",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-react": "^7.37.5",
        "global-jsdom": "^26.0.0",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "lint-staged": "^16.4.0",
        "npm-run-all-next": "^1.4.2",
        "rimraf": "^6.1.3",
        "stylelint": "^16.26.1",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-order": "^7.0.1",
        "stylelint-use-logical": "^2.1.3",
        "stylelint-value-no-unknown-custom-properties": "^6.1.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^6.4.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.6"
    }
}
